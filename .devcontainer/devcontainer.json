{
  "name": "Wassistant Devcontainer",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "forwardPorts": [8000, 3000],
  "workspaceFolder": "/workspace",
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
