{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/app-ads.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain"
          }
        ]
      },
      {
        "source": "/privacy.html",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/html"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "!**/*.{js,html,css,png,jpg,svg,json,txt,wasm,bin,webp,otf,ttf}",
        "destination": "/index.html"
      }
    ]
  }
}
