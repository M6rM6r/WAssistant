{
  "name": "wassistant-meta",
  "version": "1.4.1",
  "private": true,
  "description": "WAssistant web tooling and development configuration",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint 'web/**/*.{js,ts}' --no-error-on-unmatched-pattern --max-warnings=0",
    "lint:css": "stylelint 'web/**/*.css' || true",
    "format": "prettier --write 'web/**/*.{js,ts,css,html}'",
    "format:check": "prettier --check 'web/**/*.{js,ts,css,html}'",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run tsc",
    "prepare": "husky || true",
    "build": "tsc && npm run validate",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "lighthouse": "lighthouse build/index.html --output-path=./lighthouse-report.html",
    "bundle-analyze": "webpack-bundle-analyzer build/stats.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.0",
    "globals": "^15.13.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0",
    "lighthouse": "^11.0.0",
    "webpack-bundle-analyzer": "^4.10.0",
    "web-vitals": "^3.5.0",
    "rollup": "^4.9.0",
    "rollup-plugin-esbuild": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-commonjs": "^25.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ],
    "*.dart": [
      "dart format"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "color-hex-length": "long",
      "selector-class-pattern": null,
      "no-descending-specificity": null
    }
  }
}
